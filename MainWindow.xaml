<Window x:Class="TemperatureMonitoring.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="Temperature Monitor" Height="450" Width="800" 
        Background="#1E1E1E" Foreground="White">
    <Grid>
        <TextBox Name="ComputerNameInput" Margin="10" PlaceholderText="Enter computer name..." />
        <Button Name="ConnectButton" Content="Connect" Margin="10,40,10,0" VerticalAlignment="Top" Click="ConnectButton_Click" />
        <Button Name="RefreshButton" Content="Refresh" Margin="10,80,10,0" VerticalAlignment="Top" Click="RefreshButton_Click" />
        <TextBlock Name="StatusDisplay" Margin="10,120,10,0" Text="Status: Disconnected" />
        <DataGrid Name="TemperatureDataGrid" Margin="10,160,10,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Computer Name" Binding="ComputerName" />
                <DataGridTextColumn Header="Sensor Name" Binding="SensorName" />
                <DataGridTextColumn Header="Type" Binding="Type" />
                <DataGridTextColumn Header="Temperature" Binding="Temperature" />
                <DataGridTextColumn Header="Timestamp" Binding="Timestamp" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
